# --- Server ---
PORT=4000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# --- Database ---
# Any Postgres instance works - Neon/Supabase/Railway all have free tiers
DATABASE_URL=postgresql://user:password@localhost:5432/behealthy

# --- Auth ---
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d

# --- LLM (Anthropic) ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Email (SMTP - works with SendGrid, Mailgun, Gmail app-passwords, etc.) ---
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your_smtp_password
EMAIL_FROM="BeHealthy Clinic <no-reply@behealthy.example.com>"

# --- Google Calendar OAuth ---
GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxxxxxx
GOOGLE_REDIRECT_URI=http://localhost:4000/api/auth/google/callback

# --- Slot hold ---
SLOT_HOLD_MINUTES=5
